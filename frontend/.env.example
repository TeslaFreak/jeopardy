# Copy this file to .env.local and fill in the values from `cdk deploy` outputs.

# CDK Output: HttpApiUrl
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com

# CDK Output: WsApiUrl
VITE_WS_URL=wss://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod

# CDK Output: UserPoolId
VITE_USER_POOL_ID=us-east-1_xxxxxxxxx

# CDK Output: UserPoolClientId
VITE_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
